---
import { button } from '~/styles.ts';
import Card from '~/components/ui/Card.tsx';

export interface Props {
	name: string;
	slug: string;
	imageUrl?: string;
	cta?: string;
}
---

<Card class="overflow-hidden rounded-lg shadow-md transition-all duration-300 ease-out hover:shadow-glow hover:-translate-y-1 group">
	<a href={`/collections/${Astro.props.slug}`} class="block w-full">
		<article class="flex flex-col items-start gap-3 p-6">
			{
				Astro.props.imageUrl && (
					<div class="overflow-hidden rounded-lg">
						<img
							src={Astro.props.imageUrl.startsWith('/') ? Astro.props.imageUrl : new URL(Astro.props.imageUrl, Astro.url.origin).href}
							alt=""
							class="aspect-square size-full object-cover self-center transition-transform duration-500 ease-out group-hover:scale-110"
							loading="lazy"
							width={390}
							height={390}
						/>
					</div>
				)
			}
			<p class="text-pretty text-3xl font-semibold text-theme-base-100 transition-colors duration-300 group-hover:text-theme-accent-300">
				{Astro.props.name}
			</p>
			<p class={button({ theme: 'dark' })}>
				{Astro.props.cta ?? 'Shop now'}
			</p>
		</article>
	</a>
</Card>
