---
import type { Product } from 'storefront:client';
import { twMerge } from 'tailwind-merge';
import Card from '~/components/ui/Card.tsx';
import { formatProductPrice } from '~/lib/currency.ts';
import { productPath } from '~/paths.ts';
import { ProductPrice } from './ProductPrice.tsx';

interface Props extends Product {
	class?: string;
	elementId?: string | null;
	imageLoading?: 'eager' | 'lazy';
}

const { class: className, elementId, imageLoading, ...product } = Astro.props;
const imageSrc = product.imageUrl.startsWith('/') ? product.imageUrl : new URL(product.imageUrl, Astro.url).href;
---

<a
	href={productPath(product.slug)}
	class={twMerge(`group relative block w-full focus-visible:ring-0`, className)}
	id={elementId ?? undefined}
	aria-label={`${product.name} for ${formatProductPrice(product.price)}`}
>
	<article class="relative">
		{
			(product.discount > 0 || product.collectionIds?.includes('bestSellers')) && (
				<span class="absolute left-2 top-2 z-10 rounded bg-theme-accent-600 px-2 py-0.5 text-xs font-semibold uppercase text-white">
					New
				</span>
			)
		}
		<Card class="flex aspect-[5/6] items-center justify-center overflow-hidden">
			<img
				src={imageSrc}
				alt={product.name}
				width={290}
				height={348}
				loading={imageLoading ?? 'lazy'}
				class="size-full object-cover"
				draggable="false"
			/>
		</Card>
		<div class="flex flex-col gap-2 p-2 font-medium">
			<h3 class="text-pretty leading-tight text-theme-base-100">{product.name}</h3>
			<p class="text-lg/tight text-theme-base-400">
				<ProductPrice price={product.price} discount={product.discount} />
			</p>
		</div>
	</article>
	<div
		class="pointer-events-none absolute inset-0 ring-inset ring-theme-accent-600 group-focus-visible:ring-2"
	>
	</div>
</a>
