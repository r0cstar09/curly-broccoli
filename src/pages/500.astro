---
import CollectionSection from '~/features/collection/CollectionSection.astro';
import PrimaryLayout from '~/layouts/PrimaryLayout.astro';

export const prerender = true;
---

<PrimaryLayout title="Gitmo">
	<main>
		<div class="mx-auto my-16 grid max-w-lg lg:my-48">
			<h1 class="mb-6 text-3xl font-semibold text-theme-base-100 sm:text-5xl">Unexpected issue ⚠</h1>
			<p class="text-theme-base-300">
				Sorry, we hit an problem on our end. <a
					class="font-semibold text-theme-accent-400 underline hover:text-theme-accent-300"
					href="https://astro.build/chat">Please let us know</a
				> and we will help resolve the issue.
			</p>
		</div>
		<CollectionSection heading="Back to the shop" />
	</main>
</PrimaryLayout>
