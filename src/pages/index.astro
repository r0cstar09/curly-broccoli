---
import CollectionSection from '~/features/collection/CollectionSection.astro';
import LandingHero from '~/components/LandingHero.astro';
import ProductCarouselSection from '~/features/product/ProductCarouselSection.astro';
import { applyDefaultCacheHeaders } from '~/config.ts';
import PrimaryLayout from '~/layouts/PrimaryLayout.astro';

applyDefaultCacheHeaders(Astro.response.headers);
---

<PrimaryLayout title="Gitmo">
	<LandingHero />
	<main class="breakout mt-16 flex flex-col gap-y-16" id="products">
		<div class="content animate-fade-in-up" style="animation-delay: 0.1s; opacity: 0">
			<ProductCarouselSection heading="Fresh designs from the community" />
		</div>

		<div class="content animate-fade-in-up" style="animation-delay: 0.2s; opacity: 0">
			<ProductCarouselSection
				heading="Featured products"
				filterProducts={(products) => products.filter((p) => p.collectionIds?.includes('bestSellers'))}
			/>
		</div>

		<div class="content animate-fade-in-up" style="animation-delay: 0.3s; opacity: 0">
			<CollectionSection heading="Shop by collection" />
		</div>
	</main>
</PrimaryLayout>
