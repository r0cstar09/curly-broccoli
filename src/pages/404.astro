---
import CollectionSection from '~/features/collection/CollectionSection.astro';
import PrimaryLayout from '~/layouts/PrimaryLayout.astro';

export const prerender = true;
---

<PrimaryLayout title="Gitmo">
	<main>
		<div class="mx-auto my-16 grid max-w-xl lg:my-32">
			<h1 class="mb-6 text-3xl font-semibold text-theme-base-100 sm:text-5xl">Sorry, couldn't find that.</h1>
			<p class="text-theme-base-300">
				Looks like that page no longer exists. Let's get you <a
					class="font-semibold text-theme-accent-400 underline hover:text-theme-accent-300"
					href="/">back to the shop.</a
				>
			</p>
		</div>
		<CollectionSection heading="Shop by category" />
	</main>
</PrimaryLayout>
