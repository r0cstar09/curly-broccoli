# =============================================================================
# Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values. Never commit .env to git.
# For production, use your platform's secrets manager (Netlify, Vercel, etc.)
# =============================================================================

# -----------------------------------------------------------------------------
# Stripe (required for checkout)
# Get these from https://dashboard.stripe.com
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
US_SHIPPING_RATE_ID=
INTERNATIONAL_SHIPPING_RATE_ID=

# -----------------------------------------------------------------------------
# Loops (optional - for order confirmation emails)
# -----------------------------------------------------------------------------
LOOPS_API_KEY=
LOOPS_SHOP_TRANSACTIONAL_ID=
LOOPS_FULFILLMENT_TRANSACTIONAL_ID=
LOOPS_FULFILLMENT_EMAIL=

# -----------------------------------------------------------------------------
# Google Maps (optional - for address map on order page)
# -----------------------------------------------------------------------------
GOOGLE_GEOLOCATION_SERVER_KEY=
GOOGLE_MAPS_BROWSER_KEY=

# -----------------------------------------------------------------------------
# Analytics (optional)
# -----------------------------------------------------------------------------
FATHOM_SITE_ID=

# -----------------------------------------------------------------------------
# Custom Storefront API (optional - uses mock by default)
# -----------------------------------------------------------------------------
SHOP_API_URL=
SHOP_API_KEY=
